# ---------------------------------------------------------------------------
# Backend environment variables.
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# `.env` is already covered by .gitignore.
# ---------------------------------------------------------------------------

# SENSITIVE — database connection string.
# Local dev default is SQLite; production/staging uses the Neon Postgres URL.
# Get the pooled connection string from the Neon dashboard.
# Example shape (do NOT paste real credentials here):
#   postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require
DATABASE_URL=sqlite:///./db.sqlite3

# SENSITIVE — used to sign JWTs. Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-a-long-random-secret

# Safe-for-client / tunable auth settings.
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# SENSITIVE — Gemini API key from https://aistudio.google.com/apikey.
# Powers the AI audit pipeline (POST /api/verisphere/blogs/{id}/audit/run/).
# Leave blank to disable it; the endpoint returns a clear error instead of
# crashing the app when this is unset.
GEMINI_API_KEY=

# SENSITIVE — Resend API key from https://resend.com/api-keys.
# Sends the sign-up verification code email. Leave blank in dev: the code is
# logged to the server console instead of emailed.
RESEND_API_KEY=
VERIFICATION_EMAIL_FROM=The Synapse LE Team <noreply@synapseislive.com>
